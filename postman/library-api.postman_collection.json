                  "pm.collectionVariables.set(\"marioBorrowingId\", res.id);",
                  "pm.test(\"status 201\", () => pm.response.to.have.status(201));",
                  "pm.test(\"userFullName = Mario Rossi\", () => pm.expect(res.userFullName).to.eql(\"Mario Rossi\"));",
                  "console.log(\"createdBorrowingId:\", res.id);"
