        {
          "name": "POST /api/books (ADMIN) - crea libro",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titolo\": \"Il fu Mattia Pascal\",\n  \"autore\": \"Luigi Pirandello\",\n  \"annoPubblicazione\": 1904,\n  \"disponibile\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/books",
              "host": ["{{baseUrl}}"],
              "path": ["api", "books"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "pm.collectionVariables.set(\"createdBookId\", res.id);",
                  "pm.test(\"status 201\", () => pm.response.to.have.status(201));",
                  "pm.test(\"id valorizzato\", () => pm.expect(res.id).to.be.a(\"number\"));",
                  "console.log(\"createdBookId:\", res.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "PUT /api/books/{id} (ADMIN) - aggiorna",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titolo\": \"Il fu Mattia Pascal (ed. riveduta)\",\n  \"autore\": \"Luigi Pirandello\",\n  \"annoPubblicazione\": 1904,\n  \"disponibile\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/books/{{createdBookId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "books", "{{createdBookId}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"status 200\", () => pm.response.to.have.status(200));",
                  "pm.test(\"titolo aggiornato\", () => pm.expect(pm.response.json().titolo).to.include(\"riveduta\"));"
                ]
              }
            }
          ]
        },
        {
          "name": "DELETE /api/books/{id} (ADMIN)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
