{
  "info": {
    "name": "Library API",
    "description": "Test collection for the Workgroup Final Project library management API. Includes happy path CRUD, auth errors (401/403), validation (400), and edge cases (404/409). Tokens are auto-saved to collection variables on login.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "adminToken", "value": "" },
    { "key": "userToken", "value": "" },
    { "key": "luigiToken", "value": "" },
    { "key": "createdBookId", "value": "" },
    { "key": "createdBorrowingId", "value": "" },
    { "key": "marioBorrowingId", "value": "" }
  ],
  "item": [
    {
      "name": "1 - Auth",
      "item": [
        {
          "name": "Login Admin (saves adminToken)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@test.com\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "pm.collectionVariables.set(\"adminToken\", res.accessToken);",
                  "pm.test(\"status 200\", () => pm.response.to.have.status(200));",
                  "pm.test(\"accessToken presente\", () => pm.expect(res.accessToken).to.be.a(\"string\"));",
                  "console.log(\"adminToken salvato:\", res.accessToken);"
                ]
              }
            }
          ]
        },
        {
          "name": "Login User Mario (saves userToken)",
