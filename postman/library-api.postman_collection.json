                  "pm.test(\"status 200\", () => pm.response.to.have.status(200));",
                  "const items = pm.response.json();",
                  "pm.test(\"solo prestiti di Mario\", () => {",
                  "  if (items.length > 0) {",
                  "    items.forEach(b => pm.expect(b.userFullName).to.eql(\"Mario Rossi\"));",
